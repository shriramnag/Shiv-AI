    "# @title 🚀 शिव एआई - एंटी-स्लीप और मास्टर सेटअप\n",
    "!pip install -q gTTS transformers\n",
    "from IPython.display import display, HTML, Javascript, Audio\n",
    "import ipywidgets as widgets\n",
    "from transformers import pipeline\n",
    "from gtts import gTTS\n",
    "import os\n",
    "\n",
    "OWNER = \"Shri Ram nag\"\n",
    "def keep_alive():\n",
    "    display(Javascript('setInterval(() => { document.querySelector(\"colab-connect-button\").click(); }, 60000)'))\n",
    "keep_alive()\n",
    "print(\"✅ प्रोफेशनल फ्रंट-एंड और ३२ बॉट्स एक्टिवेटेड!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🧠 शिव एआई - एनिमेटेड वॉइस इंटरफेस (CodePen स्टाइल)\n",
    "if 'pipe' not in globals():\n",
    "    pipe = pipeline(\"text-generation\", model=\"HuggingFaceTB/SmolLM2-135M-Instruct\", device_map=\"auto\")\n",
    "\n",
    "def speak(text):\n",
    "    n_map = {\"1\":\"एक\", \"2\":\"दो\", \"3\":\"तीन\", \"4\":\"चार\", \"5\":\"पाँच\", \"0\":\"शून्य\"}\n",
    "    for n, w in n_map.items():\n",
    "        text = text.replace(n, w)\n",
    "    tts = gTTS(text, lang='hi')\n",
    "    filename = \"Shri Ram Nag.wav\"\n",
    "    tts.save(filename)\n",
    "    return filename\n",
    "\n",
    "def ai_logic(user_input):\n",
    "    sys_msg = f\"You are Shiv AI by {OWNER}. Answer in Hindi.\"\n",
    "    prompt = f\"<|system|>\\n{sys_msg}<|user|>\\n{user_input}<|assistant|>\\n\"\n",
    "    res = pipe(prompt, max_new_tokens=60, do_sample=True, temperature=0.5)\n",
    "    return res[0]['generated_text'].split(\"<|assistant|>\\n\")[-1].strip()\n",
    "\n",
    "# सुंदर फ्रंट-एंड (HTML/CSS)\n",
    "front_end = HTML('''\n",
    "<style>\n",
    "    .ai-container { background: #1e1e26; color: white; padding: 20px; border-radius: 15px; text-align: center; font-family: sans-serif; }\n",
    "    .mic-icon { width: 60px; height: 60px; background: red; border-radius: 50%; display: inline-block; margin: 10px; box-shadow: 0 0 15px red; animation: pulse 1.5s infinite; }\n",
    "    @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.1); box-shadow: 0 0 25px red; } 100% { transform: scale(1); } }\n",
    "    .status { font-size: 14px; color: #00ff00; }\n",
    "</style>\n",
    "<div class=\"ai-container\">\n",
    "    <h2>🚩 शिव एआई (Shiv AI)</h2>\n",
    "    <div class=\"mic-icon\"></div>\n",
    "    <p class=\"status\">एआई सुनने और बोलने के लिए तैयार है...</p>\n",
    "</div>\n",
    "''')\n",
    "display(front_end)\n",
    "\n",
    "out = widgets.Output()\n",
    "inp = widgets.Text(placeholder='श्री राम नाग जी, आदेश दें...', layout={'width': '80%'})\n",
    "btn = widgets.Button(description='आदेश भेजें 🚀', button_style='success')\n",
    "\n",
    "def run_chat(b):\n",
    "    with out:\n",
    "        if inp.value:\n",
    "            print(f\"👤 आप: {inp.value}\")\n",
    "            res_text = ai_logic(inp.value)\n",
    "            print(f\"🚩 शिव एआई: {res_text}\")\n",
    "            audio_file = speak(res_text)\n",
    "            display(Audio(audio_file, autoplay=True))\n",
    "            inp.value = \"\"\n",
    "\n",
    "btn.on_click(run_chat)\n",
    "display(widgets.HBox([inp, btn]), out)"
   ]
  }
 ],
