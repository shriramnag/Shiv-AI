    {
      "id": 2,
      "type": "code",
      "description": "Main AI Brain & Anti-Sleep Mechanism",
      "source": [
        "from IPython.display import display, HTML, Javascript",
        "import ipywidgets as widgets",
        "from transformers import pipeline",
        "import requests",
        "OWNER = 'Shri Ram nag'",
        "def keep_alive():",
        "    display(Javascript('setInterval(() => document.querySelector(\"colab-connect-button\").click(), 60000)'))",
        "keep_alive()",
        "if 'pipe' not in globals():",
        "    pipe = pipeline('text-generation', model='HuggingFaceTB/SmolLM2-135M-Instruct', device_map='auto')",
        "def ai_logic(user_input):",
        "    n_map = {'1':'एक', '2':'दो', '3':'तीन', '4':'चार', '5':'पाँच', '0':'शून्य'}",
        "    for n, w in n_map.items(): user_input = user_input.replace(n, w)",
        "    sys_msg = f'You are Shiv AI by {OWNER}. 32 bots available. Answer in Hindi.'",
        "    prompt = f'<|system|>\\n{sys_msg}<|user|>\\n{user_input}<|assistant|>\\n'",
        "    res = pipe(prompt, max_new_tokens=50, do_sample=True, temperature=0.5)",
        "    return res[0]['generated_text'].split('<|assistant|>\\n')[-1].strip()",
        "out = widgets.Output()",
        "inp = widgets.Text(placeholder='श्री राम नाग जी, आदेश दें...')",
        "btn = widgets.Button(description='आदेश भेजें', button_style='success')",
        "def run_chat(b):",
        "    with out:",
        "        if inp.value:",
        "            print(f'👤 आप: {inp.value}')",
        "            print(f'🚩 शिव एआई: {ai_logic(inp.value)}')",
        "            inp.value = ''",
        "btn.on_click(run_chat)",
        "display(HTML('<h2>🚩 शिव एआई - एक्टिव</h2>'), widgets.HBox([inp, btn]), out)"
      ]
    },
    {
