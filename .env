# ****************************************************************************
# प्रोजेक्ट: शिव एआई (SHIV AI) | मालिक: श्री राम नाग (Shri Ram nag)
# फाइल: .env.example (Public Template - असली कीज़ यहाँ न डालें)
# ****************************************************************************

# --- पहचान ---
OWNER_NAME=Shri Ram nag
AI_NAME=Shiv AI

# --- एपीआई कीज़ (इनकी जगह अपनी असली कीज़ डालें) ---
GRQ_API_KEY=your_groq_key_here
HF_TOKEN=your_huggingface_token_here
SERPER_API_KEY=your_search_key_here
IPSTACK_API_KEY=your_location_key_here

# --- वॉइस और सिस्टम सेटिंग्स ---
VOICE_SAMPLE_PATH=app/assets/voice_samples/shri_ram_nag.wav
OFFLINE_TTS_ENABLED=True
SYSTEM_SPEED=turbo
SECURITY_LEVEL=elite
