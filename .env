# ****************************************************************************
# प्रोजेक्ट: शिव एआई (SHIV AI) | मालिक: श्री राम नाग (Shri Ram nag)
# फाइल: .env (The Secret Power Vault)
# ****************************************************************************

# --- १. बेसिक पहचान और ओनर इन्फो ---
OWNER_NAME=Shri Ram nag
AI_NAME=Shiv AI

# --- २. कोर इंटेलिजेंस (LLM) ---
# Groq API: बिना हकलाए और सुपर फ़ास्ट रिस्पॉन्स के लिए
GRQ_API_KEY=आपका_GROQ_API_KEY_यहाँ_लिखें

# --- ३. हाइब्रिड वॉइस सेटिंग्स (Online + Offline) ---
# अगर इंटरनेट न हो तो ऑफलाइन मोड खुद सक्रिय होगा
VOICE_SAMPLE_PATH=app/assets/voice_samples/shri_ram_nag.wav
OFFLINE_TTS_ENABLED=True
CUSTOM_MODEL_PATH=Ramai.pth
VOICE_OUTPUT_FILENAME=Shri Ram Nag.wav

# --- ४. इमेज और विज़न विभाग ---
# इमेज जनरेशन और फोटो पहचानने के लिए
HF_TOKEN=आपका_HUGGINGFACE_TOKEN_यहाँ_लिखें

# --- ५. वेब नेविगेटर और डिटेक्टिव (OSINT) ---
# इंटरनेट पर सर्च करने और लोकेशन ट्रेस करने के लिए
SERPER_API_KEY=आपका_SERPER_API_KEY_यहाँ_लिखें
IPSTACK_API_KEY=आपका_IPSTACK_API_KEY_यहाँ_लिखें

# --- ६. सुरक्षा और सिस्टम सेटिंग्स ---
# टर्बो स्पीड और घोस्ट प्रोटोकॉल के लिए
SYSTEM_SPEED=turbo
SECURITY_LEVEL=elite
GHOST_PROTOCOL=enabled

# --- ७. डेटाबेस और लर्निंग ---
DATABASE_URL=sqlite:///database/learning_data/shiv_memory.db
