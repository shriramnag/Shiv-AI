    "# 🚩 शिव एआई (Shiv AI) - मास्टर ट्रेनिंग फैक्ट्री\n",
    "**मालिक:** श्री राम नाग \n",
    "इसमें प्रोग्रेस बार, गूगल ड्राइव बैकअप और री-ट्रेनिंग की सुविधा है।"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 📂 पुराने मॉडल को लोड करें (री-ट्रेनिंग फॉर्म)\n",
    "from google.colab import drive\n",
    "import os\n",
    "from unsloth import FastLanguageModel\n",
    "\n",
    "# १. ड्राइव कनेक्ट करें\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "# २. फॉर्म के जरिए रास्ता चुनें\n",
    "LOAD_FROM_DRIVE = True #@param {type:\"boolean\"}\n",
    "MODEL_PATH = \"/content/drive/MyDrive/ShivAI_Final_Model\" #@param {type:\"string\"}\n",
    "\n",
    "if LOAD_FROM_DRIVE and os.path.exists(MODEL_PATH):\n",
    "    print(f\"🔄 पुराने मॉडल को {MODEL_PATH} से लोड किया जा रहा है...\")\n",
    "    model, tokenizer = FastLanguageModel.from_pretrained(\n",
    "        model_name = MODEL_PATH,\n",
    "        max_seq_length = 2048,\n",
    "        load_in_4bit = True,\n",
    "    )\n",
    "else:\n",
    "    print(\"🆕 नया मॉडल लोड किया जा रहा है...\")\n",
    "    model, tokenizer = FastLanguageModel.from_pretrained(\n",
    "        model_name = \"HuggingFaceTB/SmolLM2-135M-Instruct\",\n",
    "        max_seq_length = 2048,\n",
    "        load_in_4bit = True,\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 🚀 प्रोग्रेस बार के साथ टर्बो ट्रेनिंग\n",
    "from trl import SFTTrainer\n",
    "from transformers import TrainingArguments\n",
    "\n",
    "trainer = SFTTrainer(\n",
    "    model = model,\n",
    "    tokenizer = tokenizer,\n",
    "    train_dataset = dataset, # आपके द्वारा बनाया गया डेटा\n",
    "    dataset_text_field = \"instruction\",\n",
    "    args = TrainingArguments(\n",
    "        max_steps = 100, \n",
    "        learning_rate = 2e-4,\n",
    "        logging_steps = 1, # हर कदम पर प्रोग्रेस दिखेगी\n",
    "        output_dir = \"outputs\",\n",
    "        report_to = \"none\",\n",
    "    ),\n",
    ")\n",
    "\n",
    "print(\"🚩 शिव एआई ट्रेनिंग शुरू... प्रोग्रेस बार नीचे देखें:\")\n",
    "trainer.train()\n",
    "print(\"✅ ट्रेनिंग १००% पूरी हुई!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title 📥 मॉडल को ड्राइव में 'लॉक' और डाउनलोड करें\n",
    "from google.colab import files\n",
    "\n",
    "SAVE_DIR = \"/content/drive/MyDrive/ShivAI_Final_Model\"\n",
    "model.save_pretrained(SAVE_DIR)\n",
    "tokenizer.save_pretrained(SAVE_DIR)\n",
    "\n",
    "print(f\"✅ मॉडल ड्राइव में सुरक्षित है: {SAVE_DIR}\")\n",
    "\n",
    "# ज़िप फाइल बनाकर डाउनलोड लिंक देना\n",
    "os.system(f\"zip -r ShivAI_Backup.zip {SAVE_DIR}\")\n",
    "files.download('ShivAI_Backup.zip')\n",
    "print(\"🚀 बैकअप फाइल तैयार है!\")"
   ]
  }
